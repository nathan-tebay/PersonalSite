# Development image — runs against a local MinIO instance (S3-compatible) by default.
FROM alpine:latest

RUN apk add --no-cache busybox-extras aws-cli

RUN mkdir -p /var/www/html /var/www/html/blog/posts
COPY . /var/www/html/

RUN cp /var/www/html/docker-entrypoint.sh /usr/local/bin/entrypoint.sh && \
    cp /var/www/html/sync-posts.sh        /usr/local/bin/sync-posts.sh && \
    chmod +x \
      /usr/local/bin/entrypoint.sh \
      /usr/local/bin/sync-posts.sh \
      /var/www/html/config.cgi \
      /var/www/html/cgi-bin/*.cgi \
      /var/www/html/cgi-bin/*.sh

RUN printf '.webp:image/webp\n.mp4:video/mp4\n' > /etc/httpd.conf

EXPOSE 8888

# STORAGE=local: CGI scripts read/write /var/www/html/blog/posts/ directly.
# No sync loop is started in local mode.
# Mount a local directory to persist posts across container restarts:
#   podman run -p 8888:8888 -v ./posts:/var/www/html/blog/posts:Z tebay-site-dev
ENV STORAGE=local

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["httpd", "-f", "-p", "8888", "-h", "/tmp/www", "-c", "/etc/httpd.conf"]
